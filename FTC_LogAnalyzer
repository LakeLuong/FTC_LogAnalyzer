import java.io.BufferedReader;
import java.io.File;
import java.io.IOException;
import java.io.InputStreamReader;
import java.nio.charset.StandardCharsets;
import java.nio.file.*;
import java.nio.file.attribute.FileTime;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;
import java.util.*;
import java.util.regex.Pattern;
import java.util.stream.Collectors;
import java.util.stream.Stream;

public class FTC_LogManager {

    private static final String USER_HOME = System.getProperty("user.home");
    private static final String ADB_PATH = USER_HOME + "\\AppData\\Local\\Android\\Sdk\\platform-tools\\adb.exe";
    private static final String ROBOT_IP = "192.168.43.1:5555";
    private static final String LOCAL_LOG_PATH = USER_HOME + "\\Desktop\\FTC_Log_Viewer";

    private static final Pattern TARGET_PATTERN = Pattern.compile(".*(\\s[EW]/|(?i)error|(?i)warning).*");
    private static final DateTimeFormatter DATE_FORMATTER =
            DateTimeFormatter.ofPattern("MM/dd/yyyy HH:mm:ss").withZone(ZoneId.systemDefault());

    static class LogInfo {
        Path path;
        int errorCount;
        String dateModified;

        LogInfo(Path path, int errorCount, String dateModified) {
            this.path = path;
            this.errorCount = errorCount;
            this.dateModified = dateModified;
        }
    }

    public static void main(String[] args) {
        System.out.println("Checking for Robot connection...");
        syncLogsFromRobot();
        analyzeLocalLogs();
    }

    private static void syncLogsFromRobot() {
        try {
            Files.createDirectories(Paths.get(LOCAL_LOG_PATH));
            System.out.println("Connecting to " + ROBOT_IP + "...");
            runCommand(ADB_PATH, "connect", ROBOT_IP);

            // Pull everything from the FIRST folder (Match logs + System logs)
            System.out.println("Downloading all logs from Robot...");
            runCommand(ADB_PATH, "pull", "/sdcard/FIRST/", LOCAL_LOG_PATH);

        } catch (Exception e) {
            System.err.println("Sync Error: " + e.getMessage());
        }
    }

    private static void analyzeLocalLogs() {
        Path dirPath = Paths.get(LOCAL_LOG_PATH);
        List<LogInfo> logFiles = new ArrayList<>();

        try (Stream<Path> paths = Files.walk(dirPath)) {
            // UPDATED FILTER: includes .txt, .txt.1, .txt.2, etc.
            List<Path> foundFiles = paths.filter(Files::isRegularFile)
                    .filter(p -> p.getFileName().toString().toLowerCase().contains(".txt"))
                    .collect(Collectors.toList());

            for (Path file : foundFiles) {
                logFiles.add(new LogInfo(file, countErrors(file), getFileDate(file)));
            }
        } catch (IOException e) {
            System.err.println("Search error: " + e.getMessage());
        }

        if (logFiles.isEmpty()) {
            System.out.println("\n[!] No log files found in: " + LOCAL_LOG_PATH);
            return;
        }

        // Sort: Most errors first
        logFiles.sort((a, b) -> Integer.compare(b.errorCount, a.errorCount));

        System.out.println("\n--- Log Analysis Menu ---");
        for (int i = 0; i < logFiles.size(); i++) {
            LogInfo info = logFiles.get(i);
            System.out.printf("[%d] %-40s | Errors: %-4d | %s%n",
                    (i + 1), info.path.getFileName(), info.errorCount, info.dateModified);
        }

        System.out.print("\nSelect a file number to parse: ");
        Scanner scanner = new Scanner(System.in);
        try {
            int choice = Integer.parseInt(scanner.nextLine());
            if (choice > 0 && choice <= logFiles.size()) {
                processLogFile(logFiles.get(choice - 1).path);
            }
        } catch (Exception e) {
            System.out.println("Exiting.");
        }
    }

    private static int countErrors(Path filePath) {
        try (Stream<String> lines = Files.lines(filePath, StandardCharsets.ISO_8859_1)) {
            return (int) lines.filter(line -> line.contains(" E/") || line.toLowerCase().contains("error")).count();
        } catch (IOException e) { return 0; }
    }

    private static String getFileDate(Path filePath) {
        try {
            return DATE_FORMATTER.format(Files.getLastModifiedTime(filePath).toInstant());
        } catch (IOException e) { return "Unknown"; }
    }

    private static void processLogFile(Path filePath) {
        System.out.println("\n--- PARSING: " + filePath.getFileName() + " ---");
        try (Stream<String> lines = Files.lines(filePath, StandardCharsets.ISO_8859_1)) {
            lines.filter(line -> TARGET_PATTERN.matcher(line).matches()).forEach(line -> {
                String prefix = (line.contains(" E/") || line.toLowerCase().contains("error")) ? "[ERROR]" : "[WARN]";
                System.out.println(prefix + " " + line);
            });
        } catch (IOException e) {
            System.err.println("Read error: " + e.getMessage());
        }
    }

    private static int runCommand(String... command) {
        try {
            ProcessBuilder pb = new ProcessBuilder(command);
            pb.redirectErrorStream(true);
            Process process = pb.start();
            return process.waitFor();
        } catch (Exception e) { return -1; }
    }
}
